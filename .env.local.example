NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# New Supabase projects should use the publishable key. The legacy anon key
# remains supported by the application during migration.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Prefer SUPABASE_SECRET_KEY for new projects. Never expose it to browser code.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# One-time only: used by auth:migrate-users when the existing super admin has
# no reusable password hash. Remove it immediately after migration.
LANFLOW_BOOTSTRAP_PASSWORD=

# Optional: only for deployment/automation scripts or server-side jobs.
# Never expose private keys in browser code or NEXT_PUBLIC_* variables.
SUPABASE_ACCESS_TOKEN=
GITHUB_TOKEN=

# Google Drive (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=1sZj8JJfX3fkaPtlSuPCRyI8rG3ZSK_A6

# OpenRouter (for OCR)
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODEL=google/gemini-2.5-flash
